# ═══════════════════════════════════════════════════
#  Grupo Win API — Variáveis de Ambiente
#  Copie para /opt/grupowin/.env e preencha os valores
# ═══════════════════════════════════════════════════

# JWT (gerado automaticamente pelo deploy.sh)
SECRET_KEY=GERAR_COM_openssl_rand_-hex_32

# Siprov ERP (ana.grupowin.site)
SIPROV_BASE_URL=https://ana.grupowin.site
SIPROV_TOKEN=SEU_TOKEN_SIPROV_AQUI

# Assist24
ASSIST24_BASE_URL=https://api.assist24.com.br
ASSIST24_TOKEN=SEU_TOKEN_ASSIST24_AQUI

# n8n
N8N_API_KEY=SEU_API_KEY_N8N

# AI (OpenAI ou compatível)
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Debug (false em produção)
DEBUG=false
