# ═══════════════════════════════════════════════════
#  Grupo Win API — Variáveis de Ambiente
#  Copie para /opt/grupowin/.env e preencha os valores
# ═══════════════════════════════════════════════════

# JWT (gerado automaticamente pelo deploy.sh)
SECRET_KEY=GERAR_COM_openssl_rand_-hex_32

# Siprov ERP (https://acesso.siprov.com.br/siprov-api)
# Auth via Basic Auth: user+password → Bearer Token (12h)
# Para obter credenciais: o admin da base cria o usuário API no Siprov e a senha chega por email
SIPROV_BASE_URL=https://acesso.siprov.com.br/siprov-api
SIPROV_USER=SEU_USUARIO_SIPROV
SIPROV_PASSWORD=SUA_SENHA_SIPROV

# Assist24
ASSIST24_BASE_URL=https://api.assist24.com.br
ASSIST24_TOKEN=SEU_TOKEN_ASSIST24_AQUI

# n8n
N8N_API_KEY=SEU_API_KEY_N8N

# AI (OpenAI ou compatível)
AI_API_KEY=sk-...
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Debug (false em produção)
DEBUG=false
